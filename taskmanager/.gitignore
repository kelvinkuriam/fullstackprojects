# Node.js dependencies — regenerated by anyone with 'npm install'
# Never commit this — it can be hundreds of megabytes
node_modules/
# Environment variables — contains secrets, NEVER commit this
.env
# The SQLite database file — contains user data
# In a real project, database data is never stored in Git
database/tasks.db
# Mac OS system file — irrelevant to the project
.DS_Store
# VS Code editor settings (optional — some teams DO commit this)
.vscode/
# npm debug logs
npm-debug.log*